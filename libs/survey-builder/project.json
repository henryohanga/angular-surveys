{
  "name": "survey-builder",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "libs/survey-builder/src",
  "prefix": "as",
  "tags": ["type:lib", "scope:shared", "platform:angular"],
  "targets": {
    "build": {
      "executor": "@nx/angular:package",
      "outputs": ["{workspaceRoot}/dist/libs/survey-builder"],
      "options": {
        "project": "libs/survey-builder/ng-package.json",
        "tsConfig": "libs/survey-builder/tsconfig.lib.json"
      },
      "configurations": {
        "production": {
          "tsConfig": "libs/survey-builder/tsconfig.lib.prod.json"
        }
      },
      "defaultConfiguration": "production"
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": {
        "lintFilePatterns": ["libs/survey-builder/**/*.ts"]
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "libs/survey-builder/jest.config.ts",
        "passWithNoTests": true
      }
    }
  }
}
