{
  "$schema": "https://unpkg.com/release-it@20/schema/release-it.json",
  "git": {
    "commitMessage": "chore: release v${version}",
    "tagName": "v${version}",
    "requireCleanWorkingDir": true,
    "requireUpstream": false
  },
  "npm": {
    "publish": false
  },
  "github": {
    "release": true,
    "releaseName": "v${version}"
  },
  "plugins": {
    "@release-it/conventional-changelog": {
      "preset": {
        "name": "angular"
      },
      "infile": "CHANGELOG.md",
      "header": "# Changelog"
    },
    "@release-it/bumper": {
      "out": [
        {
          "file": "libs/shared-types/package.json",
          "path": "version"
        },
        {
          "file": "libs/survey-renderer/package.json",
          "path": "version"
        },
        {
          "file": "libs/api-modules/package.json",
          "path": "version"
        },
        {
          "file": "libs/survey-builder/package.json",
          "path": "version"
        }
      ]
    }
  },
  "hooks": {
    "before:init": "npm run lint && npm run test:all",
    "before:release": "npm run build:all"
  }
}
