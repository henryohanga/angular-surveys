{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "../../dist/out-tsc",
    "types": [],
    "moduleResolution": "bundler",
    "baseUrl": ".",
    "paths": {
      "@angular-surveys/shared-types": ["../../libs/shared-types/src/index.ts"],
      "@angular-surveys/survey-renderer": ["../../libs/survey-renderer/src/index.ts"],
      "@angular-surveys/api-modules": ["../../libs/api-modules/src/index.ts"],
      "@angular-surveys/survey-builder": ["../../libs/survey-builder/src/index.ts"]
    }
  },
  "files": ["src/main.ts", "src/polyfills.ts"],
  "include": ["src/**/*.d.ts"],
  "exclude": ["src/**/*.spec.ts", "src/test.ts"]
}
